# Copy to .env and fill in values before running.
# MY5_ENV controls which datastore tier is used (same as the rest of the backend).
MY5_ENV=aws

# Comma-separated list of origins the API allows via CORS.
CORS_ORIGINS=http://localhost:3000

# Optional: if set, skips SQS GetQueueUrl call (avoids one extra API call per cold start).
# MY5_SQS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/ACCOUNT/my5-jobs
# MY5_SQS_DLQ_URL=https://sqs.us-east-1.amazonaws.com/ACCOUNT/my5-jobs-dlq
