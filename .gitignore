# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/

# Environments
venv/
.venv/
.venv-*/
env/
.env
*.env

# uv
.python-version

# Data — never commit raw or processed play-by-play
data/

# Terraform — state files contain resource IDs/secrets, provider cache is large
.terraform/
*.tfstate
*.tfstate.*
*.tfvars
crash.log
crash.*.log
# .terraform.lock.hcl IS committed — it pins provider versions like requirements.lock

# AWS credentials — never commit these
.aws/
*.pem
*.p12
credentials

# IDE
.vscode/
.idea/
*.swp

# macOS
.DS_Store

# Test / coverage
.pytest_cache/
.coverage
htmlcov/
